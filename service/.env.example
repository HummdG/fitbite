# Anthropic — SERVER-SIDE ONLY. Never expose this to the app / never prefix EXPO_PUBLIC_.
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Supabase — service-role key and JWT secret are SERVER-SIDE ONLY.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_JWT_SECRET=your-project-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS: comma-separated origins for the Expo dev server. Use * in dev.
CORS_ORIGINS=*
