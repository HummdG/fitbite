# Copy to .env and fill in. Only EXPO_PUBLIC_* vars are exposed to the app bundle —
# these are all safe to ship (the anon key is RLS-gated). NEVER put the Anthropic key
# or Supabase service-role key here; those live only on the FastAPI server.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# FastAPI base URL. On a real device use your machine's LAN IP, e.g. http://192.168.1.x:8000
EXPO_PUBLIC_API_URL=http://localhost:8000
